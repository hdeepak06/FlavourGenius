rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Recipes collection
    match /recipes/{recipeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
